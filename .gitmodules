	branch = docking
[submodule "3rdparty/raylib"]
	path = 3rdparty/raylib
	url = https://github.com/raysan5/raylib.git
[submodule "3rdparty/rlImGui"]
	path = 3rdparty/rlImGui
	url = https://github.com/raylib-extras/rlImGui.git
