[submodule "3rdparty/emsdk"]
	path = 3rdparty/emsdk
	url = https://github.com/emscripten-core/emsdk.git
[submodule "3rdparty/flecs"]
	path = 3rdparty/flecs
	url = https://github.com/SanderMertens/flecs.git
[submodule "3rdparty/imgui"]
	path = 3rdparty/imgui
